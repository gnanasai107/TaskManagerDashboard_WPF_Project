<Window x:Class="TaskManagerDashboard_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskManagerDashboard_WPF"
        mc:Ignorable="d"
        Title="Task Manager Dashboard" Height="500" Width="600">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Task Title and Priority Inputs -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Task -->
            <TextBlock Text="Title :" VerticalAlignment="Center" FontSize="15"/>
            <TextBox Grid.Column="1" Height="30" Text="{Binding TaskTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Priority -->
            <TextBlock Grid.Row="1" Text="Priority :" VerticalAlignment="Center" FontSize="15"/>
            <ComboBox  Grid.Row="1" Grid.Column="1" Height="30" 
                       ItemsSource="{Binding Priorities}" SelectedItem="{Binding SelectedPriority}" />
        </Grid>

        <!-- Buttons for Adding, Marking Complete, Delete-->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Add Task" Height="30" Width="180" Command="{Binding AddTaskCommand}"/>

            <Button Grid.Column="1" Content="Mark Complete" Height="30" Width="180" Command="{Binding MarkCompleteCommand}"/>

            <Button Grid.Column="2" Content="Delete Task" Height="30" Width="180" Command="{Binding DeleteTaskCommand}"/>
        </Grid>
        
        <!-- Filtering Buttons All/Completed/Pending-->
        <StackPanel Orientation="Horizontal" Margin="10">
            <Button Content="All" Command="{Binding ChangeFilterCommand}" CommandParameter="All" Margin="0,0,10,0"/>
            <Button Content="Completed" Command="{Binding ChangeFilterCommand}" CommandParameter="Completed" Margin="0,0,10,0"/>
            <Button Content="Pending" Command="{Binding ChangeFilterCommand}" CommandParameter="Pending"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Text="List of Tasks :" VerticalAlignment="Center" FontSize="15" Margin="10,0,0,0"/>
        
        <!-- List of Tasks -->
        <ListView Grid.Row="4"  ItemsSource="{Binding FilteredTasks}" SelectedItem="{Binding SelectedTask}" Margin="10,0,0,0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding TextToDisplay}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Button Grid.Row="5" Content="Save Tasks" Width="60" Command="{Binding SaveTasksCommand}" Margin="5"/>

    </Grid>
</Window>